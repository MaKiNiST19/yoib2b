PORT=3005

# Neon PostgreSQL bağlantı adresi
# https://console.neon.tech adresinden alın
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# JWT gizli anahtarı — uzun rastgele bir string girin
JWT_SECRET=change-this-to-a-long-random-secret-key

# SMTP Ayarları (e-posta bildirimleri için)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# Admin bildirim e-postası
ADMIN_EMAIL=admin@yoistudio.com

# İlk admin şifresi (ilk çalıştırmada otomatik oluşturulur)
ADMIN_INIT_PASSWORD=Admin2024!
